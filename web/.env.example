# ── Supabase ────────────────────────────────────────────────
# Создайте проект на https://supabase.com и вставьте значения.
# Если переменные не заданы — сайт работает на мок-данных (web/src/lib/mock-data.ts).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Только на сервере (Edge Functions / API routes), НЕ публиковать:
SUPABASE_SERVICE_ROLE_KEY=

# ── Telegram ────────────────────────────────────────────────
# Используется для генерации deep link "Подключить Telegram"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=jolu_bot

# ── Claude API (AI-помощник описаний туров, EN-перевод) ─────
ANTHROPIC_API_KEY=

# ── Resend (email-уведомления) ─────────────────────────────
RESEND_API_KEY=
